# Copy to .env and fill in. The API validates all of this on boot.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# SQLite file, relative to the prisma/ directory. Zero setup.
# For production, switch the datasource provider in schema.prisma to
# postgresql and point this at your Postgres connection string.
DATABASE_URL="file:./dev.db"

# Secrets MUST be at least 32 chars. Generate strong ones, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string-32-chars"

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:4200

# Set true only when served over HTTPS (adds Secure to the refresh cookie)
COOKIE_SECURE=false
